{
  "name": "agent-action-gate",
  "version": "1.3.0",
  "description": "Pre-execution safety gate for AI agents.",
  "main": "dist/server.js",
  "bin": {
    "agent-action-gate": "./dist/cli.js",
    "aag": "./dist/cli.js"
  },
  "files": [
    "src",
    "dist",
    "docs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "dev": "tsx src/server.ts",
    "dashboard": "tsx src/dashboard/server.ts",
    "dashboard:dev": "tsx src/dashboard/server.ts",
    "test": "tsx src/actionGate/tests/runAuditFoundationTests.ts && tsx src/actionGate/tests/runDistributionCopilotTests.ts && tsx src/actionGate/tests/runWorkflowScopeLedgerTests.ts && tsx src/actionGate/tests/runReceiptHashChainTests.ts && tsx src/dashboard/tests/runDashboardTests.ts",
    "test:receipt-chain": "tsx src/actionGate/tests/runReceiptHashChainTests.ts",
    "typecheck": "tsc --noEmit",
    "distribution:copilot": "tsx tools/distribution-copilot.ts",
    "eval:action-gate": "tsx src/actionGate/evals/runActionGateEvals.ts",
    "eval:high-impact": "tsx evals/high-impact-recommendation.test.ts",
    "test:logging": "tsx src/actionGate/logging/smokeTestDecisionLogger.ts"
  },
  "keywords": [],
  "author": "Michael Bower",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
